import os
import requests

UNITYSVC_API_KEY = os.getenv("UNITYSVC_API_KEY")
SERVICE_BASE_URL = os.getenv("SERVICE_BASE_URL")

def transcribe_file(path: str):
    url = f"{SERVICE_BASE_URL}/audio/transcriptions"
    headers = {"Authorization": f"Bearer {UNITYSVC_API_KEY}"}

    files = {
        "file": (path, open(path, "rb")),
        "model": (None, "{{offering.name}}")
    }

    r = requests.post(url, headers=headers, files=files)
    try:
        return r.json()
    except:
        return {"error": r.text}

# Example usage
print(transcribe_file("obamacompressed.mp4"))
