const UNITYSVC_API_KEY = process.env.UNITYSVC_API_KEY;
const ENDPOINT = "{{ service_base_url }}";

async function main() {
  const filePath = "obamacompressed.mp4";

  // Native FormData + Blob + fs for Node 18+
  const fileBuffer = await import("fs").then(fs => fs.readFileSync(filePath));
  const blob = new Blob([fileBuffer], { type: "video/mp4" });

  const form = new FormData();
  form.append("file", blob, filePath);
  form.append("model", "{{ routing_key.model }}");

  const response = await fetch(`${ENDPOINT}/audio/transcriptions`, {
    method: "POST",
    headers: {
      "Authorization": `Bearer ${UNITYSVC_API_KEY}`
    },
    body: form
  });

  const raw = await response.text();
  console.log("Raw Response:", raw);

  if (!response.ok) {
    throw new Error(`HTTP ${response.status} → ${raw}`);
  }

  console.log("Parsed:", JSON.parse(raw));
}

main();
