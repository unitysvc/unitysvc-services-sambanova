{
  "schema": "listing_v1",
  "status": "{{ status | default('ready') }}",
  "currency": "USD",
{%- if list_price %}
  "list_price": {{ list_price | tojson }},
{%- endif %}
  "user_access_interfaces": {
    "Provider API": {
      "access_method": "http",
      "base_url": "${GATEWAY_BASE_URL}/p/{{ provider_name }}",
      "routing_key": {"model": "{{ offering_name }}"}
    }
  },
  "documents": {
    "How to use this model": {
      "category": "getting_started",
      "file_path": "../../docs/description.md",
      "is_active": true,
      "is_public": true,
      "mime_type": "markdown"
    },
    "Python code example": {
      "category": "code_example",
      "description": "Example code to use the model",
      "file_path": "../../docs/{% if 'e5' in offering_name.lower() %}code-example-embed.py.j2{% elif 'whisper' in offering_name.lower() %}code-example-prerecordedtranscription.py.j2{% else %}code-example.py.j2{% endif %}",
      "is_active": true,
      "is_public": true,
      "mime_type": "python"
    },
    "Python function calling code example": {
      "category": "code_example",
      "description": "Example code to use the model",
      "file_path": "../../docs/{% if 'e5' in offering_name.lower() %}code-example-embed-fc.py.j2{% elif 'whisper' in offering_name.lower() %}code-example-prerecordedtranscription-fc.py.j2{% else %}code-example-fc.py.j2{% endif %}",
      "is_active": true,
      "is_public": true,
      "mime_type": "python"
    },
    "JavaScript code example": {
      "category": "code_example",
      "description": "Example code to use the model",
      "file_path": "../../docs/{% if 'e5' in offering_name.lower() %}code-example-embed.js.j2{% elif 'whisper' in offering_name.lower() %}code-example-prerecordedtranscription.js.j2{% else %}code-example.js.j2{% endif %}",
      "is_active": true,
      "is_public": true,
      "mime_type": "javascript"
    },
    "cURL code example": {
      "category": "code_example",
      "description": "Example code to use the model",
      "file_path": "../../docs/{% if 'e5' in offering_name.lower() %}code-example-embed.sh.j2{% elif 'whisper' in offering_name.lower() %}code-example-prerecordedtranscription.sh.j2{% else %}code-example.sh.j2{% endif %}",
      "is_active": true,
      "is_public": true,
      "mime_type": "bash"
    },
    "Connectivity test": {
      "category": "connectivity_test",
      "description": "Connectivity test",
      "file_path": "../../docs/connectivity.sh.j2",
      "is_active": true,
      "is_public": false,
      "mime_type": "bash"
    },
    "Default request body": {
          "category": "request_template",
          "description": "Default request body for the playground",
          "file_path": "../../docs/request-template.json",
          "is_active": true,
          "is_public": true,
          "mime_type": "json"
    }
  }
}