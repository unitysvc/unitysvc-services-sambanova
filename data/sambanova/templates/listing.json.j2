{%- set is_embedding = "e5" in offering_name.lower() -%}
{%- set is_transcription = "whisper" in offering_name.lower() -%}
{%- set is_chat = not (is_embedding or is_transcription) -%}

{
  "schema": "listing_v1",
  "status": "{{ status | default('ready') }}",
  "currency": "USD",
{%- if list_price %}
  "list_price": {{ list_price | tojson }},
{%- endif %}
  "user_access_interfaces": {
    "provider_api": {
      "access_method": "http",
      "base_url": "${API_GATEWAY_BASE_URL}/p/{{ provider_name }}",
      "routing_key": {"model": "{{ offering_name }}"}
    }
  },
  "documents": {
    "How to use this model": {
      "$doc_preset": "llm_description"
    },
{%- if is_embedding %}
    "Python code example": {
      "$doc_preset": "llm_code_example_embed_requests"
    },
    "Python function calling code example": {
      "$doc_preset": "llm_code_example_fc_requests"
    },
    "JavaScript code example": {
      "$doc_preset": "llm_code_example_embed_javascript"
    },
    "cURL code example": {
      "$doc_preset": "llm_code_example_embed_shell"
    },
{%- elif is_transcription %}
    "Python code example": {
      "$doc_preset": "llm_code_example_transcription_requests"
    },
    "Python function calling code example": {
      "$doc_preset": "llm_code_example_fc_requests"
    },
    "JavaScript code example": {
      "category": "code_example",
      "description": "Example code to use the model",
      "file_path": "../../docs/code-example-prerecordedtranscription.js.j2",
      "is_active": true,
      "is_public": true,
      "mime_type": "javascript"
    },
    "cURL code example": {
      "category": "code_example",
      "description": "Example code to use the model",
      "file_path": "../../docs/code-example-prerecordedtranscription.sh.j2",
      "is_active": true,
      "is_public": true,
      "mime_type": "bash"
    },
{%- else %}
    "Python code example": {
      "$doc_preset": "llm_code_example_openai"
    },
    "Python function calling code example": {
      "$doc_preset": "llm_code_example_fc_requests"
    },
    "JavaScript code example": {
      "$doc_preset": "llm_code_example_javascript"
    },
    "cURL code example": {
      "$doc_preset": "llm_code_example_shell"
    },
{%- endif %}
    "Connectivity test": {
      "$doc_preset": "llm_connectivity"
    },
    "Default request body": {
      "$doc_preset": "llm_request_template"
    }
  }
}
